<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.modules.invest.plan.fund.source.mapper.InvestFundSourceMapper">
  <resultMap id="BaseResultMap" type="com.ruoyi.modules.invest.plan.fund.source.domain.InvestFundSource">
    <id column="source_id" property="sourceId"/><result column="source_code" property="sourceCode"/><result column="source_name" property="sourceName"/><result column="source_type" property="sourceType"/><result column="subject_name" property="subjectName"/><result column="bank_name" property="bankName"/><result column="bank_account" property="bankAccount"/><result column="status" property="status"/><result column="del_flag" property="delFlag"/><result column="create_by" property="createBy"/><result column="create_time" property="createTime"/><result column="update_by" property="updateBy"/><result column="update_time" property="updateTime"/><result column="remark" property="remark"/>
  </resultMap>
  <sql id="Base_Column_List">source_id, source_code, source_name, source_type, subject_name, bank_name, bank_account, status, del_flag, create_by, create_time, update_by, update_time, remark</sql>
  <select id="selectInvestFundSourceById" resultMap="BaseResultMap">SELECT <include refid="Base_Column_List"/> FROM invest_fund_source WHERE source_id=#{sourceId} AND del_flag='0'</select>
  <select id="selectInvestFundSourceList" resultMap="BaseResultMap">SELECT <include refid="Base_Column_List"/> FROM invest_fund_source WHERE del_flag='0'<if test="sourceName != null and sourceName != ''"> AND source_name LIKE CONCAT('%',#{sourceName},'%')</if><if test="sourceType != null and sourceType != ''"> AND source_type=#{sourceType}</if><if test="status != null and status != ''"> AND status=#{status}</if> ORDER BY create_time DESC, source_id DESC</select>
  <insert id="insertInvestFundSource" useGeneratedKeys="true" keyProperty="sourceId">INSERT INTO invest_fund_source(source_code,source_name,source_type,subject_name,bank_name,bank_account,status,del_flag,create_by,create_time,remark) VALUES(#{sourceCode},#{sourceName},#{sourceType},#{subjectName},#{bankName},#{bankAccount},#{status},#{delFlag},#{createBy},#{createTime},#{remark})</insert>
  <update id="updateInvestFundSource">UPDATE invest_fund_source <set><if test="sourceCode!=null">source_code=#{sourceCode},</if><if test="sourceName!=null">source_name=#{sourceName},</if><if test="sourceType!=null">source_type=#{sourceType},</if><if test="subjectName!=null">subject_name=#{subjectName},</if><if test="bankName!=null">bank_name=#{bankName},</if><if test="bankAccount!=null">bank_account=#{bankAccount},</if><if test="status!=null">status=#{status},</if><if test="updateBy!=null">update_by=#{updateBy},</if><if test="updateTime!=null">update_time=#{updateTime},</if><if test="remark!=null">remark=#{remark},</if></set> WHERE source_id=#{sourceId}</update>
  <delete id="deleteInvestFundSourceByIds">UPDATE invest_fund_source SET del_flag='2' WHERE source_id IN <foreach item="id" collection="array" open="(" separator="," close=")">#{id}</foreach></delete>
</mapper>