<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.modules.invest.plan.fund.check.mapper.InvestFundCheckLogMapper">
  <resultMap id="BaseResultMap" type="com.ruoyi.modules.invest.plan.fund.check.domain.InvestFundCheckLog">
    <id column="log_id" property="logId"/><result column="plan_id" property="planId"/><result column="project_id" property="projectId"/><result column="budget_amount" property="budgetAmount"/><result column="planned_total" property="plannedTotal"/><result column="arrived_total" property="arrivedTotal"/><result column="paid_total" property="paidTotal"/><result column="match_rate" property="matchRate"/><result column="arrived_rate" property="arrivedRate"/><result column="paid_rate" property="paidRate"/><result column="check_result" property="checkResult"/><result column="check_type" property="checkType"/><result column="error_json" property="errorJson"/><result column="create_by" property="createBy"/><result column="create_time" property="createTime"/>
  </resultMap>
  <sql id="Base_Column_List">log_id,plan_id,project_id,budget_amount,planned_total,arrived_total,paid_total,match_rate,arrived_rate,paid_rate,check_result,check_type,error_json,create_by,create_time</sql>
  <select id="selectInvestFundCheckLogById" resultMap="BaseResultMap">SELECT <include refid="Base_Column_List"/> FROM invest_fund_check_log WHERE log_id=#{logId}</select>
  <select id="selectInvestFundCheckLogList" resultMap="BaseResultMap">SELECT <include refid="Base_Column_List"/> FROM invest_fund_check_log WHERE 1=1<if test="planId!=null"> AND plan_id=#{planId}</if><if test="projectId!=null"> AND project_id=#{projectId}</if><if test="checkResult!=null and checkResult!=''"> AND check_result=#{checkResult}</if> ORDER BY create_time DESC,log_id DESC</select>
  <select id="selectLogsByPlanId" resultMap="BaseResultMap">SELECT <include refid="Base_Column_List"/> FROM invest_fund_check_log WHERE plan_id=#{planId} ORDER BY create_time DESC,log_id DESC</select>
  <insert id="insertInvestFundCheckLog" useGeneratedKeys="true" keyProperty="logId">INSERT INTO invest_fund_check_log(plan_id,project_id,budget_amount,planned_total,arrived_total,paid_total,match_rate,arrived_rate,paid_rate,check_result,check_type,error_json,create_by,create_time) VALUES(#{planId},#{projectId},#{budgetAmount},#{plannedTotal},#{arrivedTotal},#{paidTotal},#{matchRate},#{arrivedRate},#{paidRate},#{checkResult},#{checkType},#{errorJson},#{createBy},#{createTime})</insert>
</mapper>