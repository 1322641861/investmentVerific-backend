<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.modules.invest.plan.fund.plan.mapper.InvestFundPlanMapper">
  <resultMap id="BaseResultMap" type="com.ruoyi.modules.invest.plan.fund.plan.domain.InvestFundPlan">
    <id column="plan_id" property="planId"/><result column="plan_code" property="planCode"/><result column="project_id" property="projectId"/><result column="project_code" property="projectCode"/><result column="project_name" property="projectName"/><result column="scheme_id" property="schemeId"/><result column="budget_id" property="budgetId"/><result column="budget_item_id" property="budgetItemId"/><result column="budget_amount" property="budgetAmount"/><result column="plan_total" property="planTotal"/><result column="arrived_total" property="arrivedTotal"/><result column="paid_total" property="paidTotal"/><result column="match_rate" property="matchRate"/><result column="plan_status" property="planStatus"/><result column="last_check_status" property="lastCheckStatus"/><result column="last_check_time" property="lastCheckTime"/><result column="process_instance_id" property="processInstanceId"/><result column="version_no" property="versionNo"/><result column="del_flag" property="delFlag"/><result column="create_by" property="createBy"/><result column="create_time" property="createTime"/><result column="update_by" property="updateBy"/><result column="update_time" property="updateTime"/><result column="remark" property="remark"/>
  </resultMap>
  <sql id="Base_Column_List">plan_id,plan_code,project_id,project_code,project_name,scheme_id,budget_id,budget_item_id,budget_amount,plan_total,arrived_total,paid_total,match_rate,plan_status,last_check_status,last_check_time,process_instance_id,version_no,del_flag,create_by,create_time,update_by,update_time,remark</sql>
  <select id="selectInvestFundPlanById" resultMap="BaseResultMap">SELECT <include refid="Base_Column_List"/> FROM invest_fund_plan WHERE plan_id=#{planId} AND del_flag='0'</select>
  <select id="selectInvestFundPlanByProjectId" resultMap="BaseResultMap">SELECT <include refid="Base_Column_List"/> FROM invest_fund_plan WHERE project_id=#{projectId} AND del_flag='0' LIMIT 1</select>
  <select id="selectInvestFundPlanList" resultMap="BaseResultMap">SELECT <include refid="Base_Column_List"/> FROM invest_fund_plan WHERE del_flag='0'<if test="projectName!=null and projectName!=''"> AND project_name LIKE CONCAT('%',#{projectName},'%')</if><if test="schemeId!=null"> AND scheme_id=#{schemeId}</if><if test="planStatus!=null and planStatus!=''"> AND plan_status=#{planStatus}</if> ORDER BY create_time DESC, plan_id DESC</select>
  <insert id="insertInvestFundPlan" useGeneratedKeys="true" keyProperty="planId">INSERT INTO invest_fund_plan(plan_code,project_id,project_code,project_name,scheme_id,budget_id,budget_item_id,budget_amount,plan_total,arrived_total,paid_total,match_rate,plan_status,last_check_status,last_check_time,process_instance_id,version_no,del_flag,create_by,create_time,remark) VALUES(#{planCode},#{projectId},#{projectCode},#{projectName},#{schemeId},#{budgetId},#{budgetItemId},#{budgetAmount},#{planTotal},#{arrivedTotal},#{paidTotal},#{matchRate},#{planStatus},#{lastCheckStatus},#{lastCheckTime},#{processInstanceId},#{versionNo},#{delFlag},#{createBy},#{createTime},#{remark})</insert>
  <update id="updateInvestFundPlan">UPDATE invest_fund_plan <set><if test="planCode!=null">plan_code=#{planCode},</if><if test="projectId!=null">project_id=#{projectId},</if><if test="projectCode!=null">project_code=#{projectCode},</if><if test="projectName!=null">project_name=#{projectName},</if><if test="schemeId!=null">scheme_id=#{schemeId},</if><if test="budgetId!=null">budget_id=#{budgetId},</if><if test="budgetItemId!=null">budget_item_id=#{budgetItemId},</if><if test="budgetAmount!=null">budget_amount=#{budgetAmount},</if><if test="planTotal!=null">plan_total=#{planTotal},</if><if test="arrivedTotal!=null">arrived_total=#{arrivedTotal},</if><if test="paidTotal!=null">paid_total=#{paidTotal},</if><if test="matchRate!=null">match_rate=#{matchRate},</if><if test="planStatus!=null">plan_status=#{planStatus},</if><if test="processInstanceId!=null">process_instance_id=#{processInstanceId},</if><if test="updateBy!=null">update_by=#{updateBy},</if><if test="updateTime!=null">update_time=#{updateTime},</if><if test="remark!=null">remark=#{remark},</if></set> WHERE plan_id=#{planId} AND del_flag='0'</update>
  <update id="updatePlanAmounts">UPDATE invest_fund_plan SET plan_total=#{planTotal}, match_rate=#{matchRate}, update_by=#{updateBy}, update_time=#{updateTime} WHERE plan_id=#{planId}</update>
  <update id="updateCheckStatus">UPDATE invest_fund_plan SET last_check_status=#{lastCheckStatus}, last_check_time=#{lastCheckTime}, update_by=#{updateBy}, update_time=#{updateTime} WHERE plan_id=#{planId}</update>
  <delete id="deleteInvestFundPlanByIds">UPDATE invest_fund_plan SET del_flag='2' WHERE plan_id IN <foreach item="id" collection="array" open="(" separator="," close=")">#{id}</foreach></delete>
</mapper>