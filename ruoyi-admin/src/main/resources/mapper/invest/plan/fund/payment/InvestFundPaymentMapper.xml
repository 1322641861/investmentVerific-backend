  <sql id="Base_Column_List">payment_id,payment_code,plan_id,project_id,project_name,apply_amount,paid_amount,payee_name,payee_bank,payee_account,purpose,attachment,pay_status,apply_date,pay_date,process_instance_id,create_by,create_time,update_by,update_time,remark</sql>
  <select id="selectInvestFundPaymentById" resultMap="BaseResultMap">SELECT <include refid="Base_Column_List"/> FROM invest_fund_payment WHERE payment_id=#{paymentId}</select>
  <select id="selectInvestFundPaymentList" resultMap="BaseResultMap">SELECT <include refid="Base_Column_List"/> FROM invest_fund_payment WHERE 1=1<if test="planId!=null"> AND plan_id=#{planId}</if><if test="payStatus!=null and payStatus!=''"> AND pay_status=#{payStatus}</if> ORDER BY create_time DESC,payment_id DESC</select>
  <insert id="insertInvestFundPayment" useGeneratedKeys="true" keyProperty="paymentId">INSERT INTO invest_fund_payment(payment_code,plan_id,project_id,project_name,apply_amount,paid_amount,payee_name,payee_bank,payee_account,purpose,attachment,pay_status,apply_date,pay_date,process_instance_id,create_by,create_time,remark) VALUES(#{paymentCode},#{planId},#{projectId},#{projectName},#{applyAmount},#{paidAmount},#{payeeName},#{payeeBank},#{payeeAccount},#{purpose},#{attachment},#{payStatus},#{applyDate},#{payDate},#{processInstanceId},#{createBy},#{createTime},#{remark})</insert>
  <update id="updateInvestFundPayment">UPDATE invest_fund_payment <set><if test="paymentCode!=null">payment_code=#{paymentCode},</if><if test="planId!=null">plan_id=#{planId},</if><if test="projectId!=null">project_id=#{projectId},</if><if test="projectName!=null">project_name=#{projectName},</if><if test="applyAmount!=null">apply_amount=#{applyAmount},</if><if test="paidAmount!=null">paid_amount=#{paidAmount},</if><if test="payeeName!=null">payee_name=#{payeeName},</if><if test="payeeBank!=null">payee_bank=#{payeeBank},</if><if test="payeeAccount!=null">payee_account=#{payeeAccount},</if><if test="purpose!=null">purpose=#{purpose},</if><if test="attachment!=null">attachment=#{attachment},</if><if test="payStatus!=null">pay_status=#{payStatus},</if><if test="applyDate!=null">apply_date=#{applyDate},</if><if test="payDate!=null">pay_date=#{payDate},</if><if test="processInstanceId!=null">process_instance_id=#{processInstanceId},</if><if test="updateBy!=null">update_by=#{updateBy},</if><if test="updateTime!=null">update_time=#{updateTime},</if><if test="remark!=null">remark=#{remark},</if></set> WHERE payment_id=#{paymentId}</update>
  <delete id="deleteInvestFundPaymentByIds">DELETE FROM invest_fund_payment WHERE payment_id IN <foreach item="id" collection="array" open="(" separator="," close=")">#{id}</foreach></delete>
