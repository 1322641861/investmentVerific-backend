<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.modules.invest.attachment.mapper.InvestAttachmentMapper">
    <resultMap type="com.ruoyi.modules.invest.attachment.domain.InvestAttachment" id="AttachmentResult">
        <id column="attachment_id" property="attachmentId"/>
        <result column="business_type" property="businessType"/><result column="business_id" property="businessId"/>
        <result column="file_name" property="fileName"/><result column="file_path" property="filePath"/>
        <result column="file_size" property="fileSize"/><result column="file_type" property="fileType"/>
        <result column="file_ext" property="fileExt"/><result column="upload_by" property="uploadBy"/>
        <result column="upload_time" property="uploadTime"/><result column="del_flag" property="delFlag"/>
        <result column="create_by" property="createBy"/><result column="create_time" property="createTime"/>
    </resultMap>
    <sql id="selectVo">SELECT * FROM invest_attachment</sql>
    <select id="selectById" resultMap="AttachmentResult"><include refid="selectVo"/> WHERE attachment_id=#{id}</select>
    <select id="selectList" resultMap="AttachmentResult"><include refid="selectVo"/><where>del_flag='0'<if test="businessType!=null">AND business_type=#{businessType}</if><if test="fileName!=null and fileName!=''">AND file_name LIKE CONCAT('%',#{fileName},'%')</if></where>ORDER BY upload_time DESC</select>
    <select id="selectByBusiness" resultMap="AttachmentResult"><include refid="selectVo"/> WHERE business_type=#{businessType} AND business_id=#{businessId} AND del_flag='0' ORDER BY upload_time</select>
    <insert id="insert" useGeneratedKeys="true" keyProperty="attachmentId">INSERT INTO invest_attachment(business_type,business_id,file_name,file_path,file_size,file_type,file_ext,upload_by,upload_time,del_flag,create_by,create_time)VALUES(#{businessType},#{businessId},#{fileName},#{filePath},#{fileSize},#{fileType},#{fileExt},#{uploadBy},#{uploadTime},'0',#{createBy},#{createTime})</insert>
    <delete id="deleteByIds">UPDATE invest_attachment SET del_flag='2' WHERE attachment_id IN<foreach collection="array" item="id" open="(" separator="," close=")">#{id}</foreach></delete>
    <delete id="deleteByBusiness">UPDATE invest_attachment SET del_flag='2' WHERE business_type=#{businessType} AND business_id=#{businessId}</delete>
</mapper>
