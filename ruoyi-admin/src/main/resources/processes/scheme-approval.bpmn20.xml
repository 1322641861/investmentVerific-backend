<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
    xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
    xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
    xmlns:flowable="http://flowable.org/bpmn"
    targetNamespace="http://www.flowable.org/processdef"
    id="definitions">

  <process id="plan_scheme_approval" name="规划方案审批流程" isExecutable="true">

    <startEvent id="start" name="开始审批"></startEvent>

    <userTask id="task1" name="部门经理审核"
              flowable:assignee="${managerUserId}"
              flowable:candidateUsers="${managerRole}">
      <documentation>请审核规划方案内容</documentation>
    </userTask>

    <exclusiveGateway id="gateway1" name="审核结果判断"></exclusiveGateway>

    <userTask id="task2" name="财务复核"
              flowable:assignee="${financeUserId}"
              flowable:candidateUsers="${financeRole}">
      <documentation>请复核规划方案预算</documentation>
    </userTask>

    <userTask id="task3" name="副总经理审批"
              flowable:assignee="${vpUserId}"
              flowable:candidateUsers="${vpRole}">
      <documentation>请最终审批规划方案</documentation>
    </userTask>

    <endEvent id="endApproved" name="审批通过">
      <documentation>规划方案审批通过</documentation>
      <extensionElements>
        <flowable:executionListener event="end" delegateExpression="${processStatusExecutionListener}" />
      </extensionElements>
    </endEvent>

    <endEvent id="endRejected" name="审批驳回">
      <documentation>规划方案审批驳回</documentation>
      <extensionElements>
        <flowable:executionListener event="end" delegateExpression="${processStatusExecutionListener}" />
      </extensionElements>
    </endEvent>

    <sequenceFlow id="flow1" sourceRef="start" targetRef="task1"></sequenceFlow>
    <sequenceFlow id="flow2" sourceRef="task1" targetRef="gateway1"></sequenceFlow>

    <sequenceFlow id="flowApproved1" sourceRef="gateway1" targetRef="task2" name="通过">
      <conditionExpression xsi:type="tFormalExpression">${outcome == 'approve'}</conditionExpression>
    </sequenceFlow>

    <sequenceFlow id="flowRejected1" sourceRef="gateway1" targetRef="endRejected" name="驳回">
      <conditionExpression xsi:type="tFormalExpression">${outcome == 'reject'}</conditionExpression>
    </sequenceFlow>

    <exclusiveGateway id="gateway2" name="财务复核判断"></exclusiveGateway>
    <sequenceFlow id="flow3" sourceRef="task2" targetRef="gateway2"></sequenceFlow>

    <sequenceFlow id="flowApproved2" sourceRef="gateway2" targetRef="task3" name="通过">
      <conditionExpression xsi:type="tFormalExpression">${outcome == 'approve'}</conditionExpression>
    </sequenceFlow>

    <sequenceFlow id="flowRejected2" sourceRef="gateway2" targetRef="endRejected" name="驳回">
      <conditionExpression xsi:type="tFormalExpression">${outcome == 'reject'}</conditionExpression>
    </sequenceFlow>

    <exclusiveGateway id="gateway3" name="副总经理审批判断"></exclusiveGateway>
    <sequenceFlow id="flow4" sourceRef="task3" targetRef="gateway3"></sequenceFlow>

    <sequenceFlow id="flowApproved3" sourceRef="gateway3" targetRef="endApproved" name="通过">
      <conditionExpression xsi:type="tFormalExpression">${outcome == 'approve'}</conditionExpression>
    </sequenceFlow>

    <sequenceFlow id="flowRejected3" sourceRef="gateway3" targetRef="endRejected" name="驳回">
      <conditionExpression xsi:type="tFormalExpression">${outcome == 'reject'}</conditionExpression>
    </sequenceFlow>

  </process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_scheme-approval">
    <bpmndi:BPMNPlane id="BPMNPlane_plan_scheme_approval" bpmnElement="plan_scheme_approval">
      <bpmndi:BPMNShape id="start_shape" bpmnElement="start" isMarkerVisible="true">
        <dc:Bounds x="100" y="100" width="30" height="30"></dc:Bounds>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task1_shape" bpmnElement="task1" isMarkerVisible="true">
        <dc:Bounds x="200" y="80" width="100" height="80"></dc:Bounds>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gateway1_shape" bpmnElement="gateway1" isMarkerVisible="true">
        <dc:Bounds x="360" y="100" width="40" height="40"></dc:Bounds>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task2_shape" bpmnElement="task2" isMarkerVisible="true">
        <dc:Bounds x="450" y="80" width="100" height="80"></dc:Bounds>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gateway2_shape" bpmnElement="gateway2" isMarkerVisible="true">
        <dc:Bounds x="600" y="100" width="40" height="40"></dc:Bounds>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task3_shape" bpmnElement="task3" isMarkerVisible="true">
        <dc:Bounds x="690" y="80" width="100" height="80"></dc:Bounds>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gateway3_shape" bpmnElement="gateway3" isMarkerVisible="true">
        <dc:Bounds x="840" y="100" width="40" height="40"></dc:Bounds>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="endApproved_shape" bpmnElement="endApproved" isMarkerVisible="true">
        <dc:Bounds x="950" y="100" width="30" height="30"></dc:Bounds>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="endRejected_shape" bpmnElement="endRejected" isMarkerVisible="true">
        <dc:Bounds x="360" y="250" width="30" height="30"></dc:Bounds>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="flow1_edge" bpmnElement="flow1">
        <di:waypoint x="130" y="115"></di:waypoint>
        <di:waypoint x="200" y="120"></di:waypoint>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow2_edge" bpmnElement="flow2">
        <di:waypoint x="300" y="120"></di:waypoint>
        <di:waypoint x="360" y="120"></di:waypoint>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flowApproved1_edge" bpmnElement="flowApproved1">
        <di:waypoint x="400" y="100"></di:waypoint>
        <di:waypoint x="450" y="120"></di:waypoint>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flowRejected1_edge" bpmnElement="flowRejected1">
        <di:waypoint x="380" y="140"></di:waypoint>
        <di:waypoint x="375" y="250"></di:waypoint>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow3_edge" bpmnElement="flow3">
        <di:waypoint x="550" y="120"></di:waypoint>
        <di:waypoint x="600" y="120"></di:waypoint>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flowApproved2_edge" bpmnElement="flowApproved2">
        <di:waypoint x="640" y="100"></di:waypoint>
        <di:waypoint x="690" y="120"></di:waypoint>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flowRejected2_edge" bpmnElement="flowRejected2">
        <di:waypoint x="620" y="140"></di:waypoint>
        <di:waypoint x="375" y="265"></di:waypoint>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow4_edge" bpmnElement="flow4">
        <di:waypoint x="790" y="120"></di:waypoint>
        <di:waypoint x="840" y="120"></di:waypoint>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flowApproved3_edge" bpmnElement="flowApproved3">
        <di:waypoint x="880" y="100"></di:waypoint>
        <di:waypoint x="950" y="115"></di:waypoint>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flowRejected3_edge" bpmnElement="flowRejected3">
        <di:waypoint x="860" y="140"></di:waypoint>
        <di:waypoint x="375" y="265"></di:waypoint>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</definitions>
